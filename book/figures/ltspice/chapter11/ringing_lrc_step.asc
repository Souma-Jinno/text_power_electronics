Version 4
SHEET 1 880 680
WIRE 160 16 720 16
FLAG 160 112 0
FLAG 720 208 vcp
FLAG 720 304 0
SYMBOL voltage 160 16 R0
SYMATTR InstName V1
SYMATTR Value PULSE(0 10 0 {tr} {tr} 5000n 10000n)
SYMBOL ind 720 16 R0
SYMATTR InstName Lp
SYMATTR Value 40n
SYMBOL res 720 112 R0
SYMATTR InstName R1
SYMATTR Value 0.1
SYMBOL cap 720 208 R0
SYMATTR InstName Cp
SYMATTR Value 0.1n
TEXT 112 -40 Left 2 ;直列RLC寄生共振回路(sec11.5, fig11.5(a), ex11.5) V1(step)-Lp-R1-Cp-GND
TEXT 112 -16 Left 2 ;Lp=40nH, R1=0.1ohm(基準), Cp=0.1nF, 振幅10Vステップ。v(vcp)=Cp両端電圧を観測
TEXT 112 400 Left 2 !.param tr=1n
TEXT 112 424 Left 2 !.control
TEXT 112 448 Left 2 !tran 5p 3u
TEXT 112 472 Left 2 !meas tran vpeak_a MAX v(vcp) FROM=0 TO=200n
TEXT 112 496 Left 2 !meas tran t_zc1_a WHEN v(vcp)=10 RISE=2
TEXT 112 520 Left 2 !meas tran t_zc2_a WHEN v(vcp)=10 RISE=3
TEXT 112 544 Left 2 !meas tran pk2_a MAX v(vcp) FROM=12.5n TO=25n
TEXT 112 568 Left 2 !meas tran pk3_a MAX v(vcp) FROM=25n TO=37.5n
TEXT 112 592 Left 2 !print vpeak_a t_zc1_a t_zc2_a pk2_a pk3_a
TEXT 112 616 Left 2 !alterparam tr=100n
TEXT 112 640 Left 2 !reset
TEXT 112 664 Left 2 !tran 5p 3u
TEXT 112 688 Left 2 !meas tran vpeak_b1 MAX v(vcp) FROM=0 TO=1000n
TEXT 112 712 Left 2 !print vpeak_b1
TEXT 112 736 Left 2 !alterparam tr=1n
TEXT 112 760 Left 2 !reset
TEXT 112 784 Left 2 !alter R1=1
TEXT 112 808 Left 2 !tran 5p 3u
TEXT 112 832 Left 2 !meas tran vpeak_b2 MAX v(vcp) FROM=0 TO=12.5n
TEXT 112 856 Left 2 !meas tran pk2_b2 MAX v(vcp) FROM=12.5n TO=25n
TEXT 112 880 Left 2 !meas tran pk3_b2 MAX v(vcp) FROM=25n TO=37.5n
TEXT 112 904 Left 2 !print vpeak_b2 pk2_b2 pk3_b2
TEXT 112 928 Left 2 !write chapter11/ringing_lrc_step.raw all
TEXT 112 952 Left 2 !.endc
