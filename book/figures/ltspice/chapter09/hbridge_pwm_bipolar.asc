SYMBOL voltage 900 50 R0
SYMATTR InstName Bcarr
SYMATTR Value V=(2/pi*asin(sin(2*pi*fc*time)))
SYMBOL voltage 900 250 R0
SYMATTR InstName Bref
SYMATTR Value V=(m*sin(2*pi*fm*time))
SYMBOL voltage 900 450 R0
SYMATTR InstName BctrlA
SYMATTR Value V=((V(ref)>V(carr))?1:0)
SYMBOL voltage 900 650 R0
SYMATTR InstName BctrlAn
SYMATTR Value V=((V(ref)<V(carr))?1:0)
TEXT 0 -160 Left 2 ;フルブリッジ正弦波PWM・バイポーラ変調(sec9.5, ex9.6基準)
TEXT 0 -128 Left 2 ;E=100V(本文はex9.6でE未指定、rei9.3/ex9.1(c)と同じ100Vを採用) fc=5kHz(搬送波) fm=50Hz(変調波) m=0.8(既定、章末問題(d)でスイープ)
TEXT 0 -96 Left 2 ;負荷R=10ohm L=10mH(RL直列、本文指定値)。対角ペア(S1,S4)と(S2,S3)が同時にON/OFFする(バイポーラ=出力+-Eの2値)
TEXT 900 -32 Left 2 ;制御ブロック(Bcarr/Bref/BctrlA/BctrlAn): voltageシンボルを流用したngspice behavioral source(B-element, Value=V=式)。
TEXT 900 -8 Left 2 ;視覚上は電圧源記号だが実体は三角搬送波生成・正弦波基準・比較器(PWMコンパレータ)というcontrol block(opamp/zenerと同じ簡略化方針)
TEXT 0 780 Left 2 !.model SW SW(Ron=10m Roff=1G Vt=0.5)
TEXT 0 804 Left 2 !.param E=100 fc=5k fm=50 m=0.8 R=10 L=10m
TEXT 0 828 Left 2 !.options reltol=0.01 gmin=1e-9
TEXT 0 852 Left 2 !.control
TEXT 0 876 Left 2 !* m=0.5
TEXT 0 900 Left 2 !alterparam m = 0.5
TEXT 0 924 Left 2 !reset
TEXT 0 948 Left 2 !tran 0.5u 40m 20m 2u
TEXT 0 972 Left 2 !let vab = v(a) - v(b)
TEXT 0 996 Left 2 !let sinref = sin(2*3.14159265358979*50*time)
TEXT 0 1020 Left 2 !let ib = vab*sinref
TEXT 0 1044 Left 2 !meas tran vmax_m05 max vab from=20m to=39.9m
TEXT 0 1068 Left 2 !meas tran ib_m05 integ ib from=20m to=39.9m
TEXT 0 1092 Left 2 !* m=0.8 (主要ケース, ex9.6(a)(b)(c)の基準)
TEXT 0 1116 Left 2 !alterparam m = 0.8
TEXT 0 1140 Left 2 !reset
TEXT 0 1164 Left 2 !tran 0.5u 40m 20m 2u
TEXT 0 1188 Left 2 !let vab = v(a) - v(b)
TEXT 0 1212 Left 2 !let sinref = sin(2*3.14159265358979*50*time)
TEXT 0 1236 Left 2 !let ib = vab*sinref
TEXT 0 1260 Left 2 !meas tran vmax_m08 max vab from=20m to=39.9m
TEXT 0 1284 Left 2 !meas tran vmin_m08 min vab from=20m to=39.9m
TEXT 0 1308 Left 2 !meas tran irms_m08 rms i(l1) from=20m to=39.9m
TEXT 0 1332 Left 2 !meas tran ipeak_m08 max i(l1) from=20m to=39.9m
TEXT 0 1356 Left 2 !meas tran ib_m08 integ ib from=20m to=39.9m
TEXT 0 1380 Left 2 !linearize vab
TEXT 0 1404 Left 2 !fft vab
TEXT 0 1428 Left 2 !* m=1.0
TEXT 0 1452 Left 2 !alterparam m = 1.0
TEXT 0 1476 Left 2 !reset
TEXT 0 1500 Left 2 !tran 0.5u 40m 20m 2u
TEXT 0 1524 Left 2 !let vab = v(a) - v(b)
TEXT 0 1548 Left 2 !let sinref = sin(2*3.14159265358979*50*time)
TEXT 0 1572 Left 2 !let ib = vab*sinref
TEXT 0 1596 Left 2 !meas tran vmax_m10 max vab from=20m to=39.9m
TEXT 0 1620 Left 2 !meas tran ib_m10 integ ib from=20m to=39.9m
TEXT 0 1644 Left 2 !* m=1.2 (過変調)
TEXT 0 1668 Left 2 !alterparam m = 1.2
TEXT 0 1692 Left 2 !reset
TEXT 0 1716 Left 2 !tran 0.5u 40m 20m 2u
TEXT 0 1740 Left 2 !let vab = v(a) - v(b)
TEXT 0 1764 Left 2 !let sinref = sin(2*3.14159265358979*50*time)
TEXT 0 1788 Left 2 !let ib = vab*sinref
TEXT 0 1812 Left 2 !meas tran vmax_m12 max vab from=20m to=39.9m
TEXT 0 1836 Left 2 !meas tran ib_m12 integ ib from=20m to=39.9m
TEXT 0 1860 Left 2 !write chapter09/hbridge_pwm_bipolar.raw all
TEXT 0 1884 Left 2 !.endc
